# App icon settings
macos-icon = xray

# Window settings
macos-titlebar-style = "transparent"
shell-integration = "detect"

# Cursor settings
shell-integration-features = sudo, no-cursor, title
cursor-style = underline
cursor-style-blink = false
# mac opt as alt
macos-option-as-alt = left

# Default working directory settings
working-directory = home

# Font settings
font-family = "MesloLGS Nerd Font Mono"
font-family-bold = "MesloLGS Nerd Font Mono"
font-family-italic = "MesloLGS Nerd Font Mono"
font-family-bold-italic = "MesloLGS Nerd Font Mono"
font-size = 15

# Theme settings
theme = catppuccin-mocha.conf

# Quick terminal settings
keybind = global:cmd+`=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-autohide = true
quick-terminal-space-behavior = move

# tmux handles splits/windows — ghostty is just the container
mouse-hide-while-typing = true
scrollback-limit = 10000
command = /Users/varunv/.config/ghostty/tmux-start.sh

window-save-state = always

background-opacity = 1.00
