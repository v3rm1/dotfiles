s () {
  fz --ansi --disabled \
      --bind "change:reload:command \
          rg --line-number --no-heading --color=always --smart-case {q} \
          || :" \
      --bind "enter:execute(${EDITOR:-nvim} +{2} {1})" \
      --delimiter ":" \
      --preview "command bat -p --color=always {1} --highlight-line {2}" \
      --preview-window 'up:80%,border-bottom,~3,+{2}+3/3'
}

# Give each tmux pane's nvim instance a predictable RPC socket so
# keymaster can query its live keymaps/mode.
nvim() {
    if [ -n "$TMUX" ]; then
        command nvim --listen "/tmp/nvim-$(tmux display -p '#{pane_id}').sock" "$@"
    else
        command nvim "$@"
    fi
}
